# Composer dependencies
/vendor/
/composer.lock

# Build / distribution artifacts
/build/
/dist/
/*.phar

# Logs and runtime cache
/var/cache/*
!/var/cache/.gitkeep
/var/log/*
!/var/log/.gitkeep
/var/sessions/*
!/var/sessions/.gitkeep
/var/migrations/*
!/var/migrations/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep
/coverage/

# IDE / editor settings
/.idea/
/.vscode/
/nbproject/
/*.sublime-workspace
/*.sublime-project

# Environment files
.env
.env.*.local
.env.local
.env.testing

# PHPUnit and test artifacts
/.phpunit.cache/
/phpunit.result.cache

# PHPStan cache
/var/cache/phpstan/

# OS-specific files
.DS_Store
Thumbs.db