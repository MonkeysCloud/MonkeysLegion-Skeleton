###############################################################################
#  MonkeysLegion v2 – Environment Configuration                               #
#  Rename to `.env` for local use — NEVER commit this file                    #
###############################################################################

# ═══════════════════════════════════════════════════════════════════════════════
# Application
# ═══════════════════════════════════════════════════════════════════════════════

APP_NAME="MonkeysLegion App"
# production | staging | development | testing
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
# APP_KEY=base64:...  (Generated by `php ml key:generate`)

# ═══════════════════════════════════════════════════════════════════════════════
# Database (MySQL 8.4+ / PostgreSQL 16+)
# ═══════════════════════════════════════════════════════════════════════════════

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ml_skeleton
DB_USERNAME=root
DB_PASSWORD=root
DB_CHARSET=utf8mb4

# ═══════════════════════════════════════════════════════════════════════════════
# Authentication
# ═══════════════════════════════════════════════════════════════════════════════

JWT_SECRET=changeme-use-at-least-32-characters-of-randomness
# JWT_ACCESS_TTL — 30 minutes
JWT_ACCESS_TTL=1800
# JWT_REFRESH_TTL — 7 days
JWT_REFRESH_TTL=604800

# ═══════════════════════════════════════════════════════════════════════════════
# Session
# ═══════════════════════════════════════════════════════════════════════════════

# file | database | redis
SESSION_DRIVER=file
# Session lifetime in seconds
SESSION_LIFETIME=7200
SESSION_ENCRYPT=false

# ═══════════════════════════════════════════════════════════════════════════════
# Cache
# ═══════════════════════════════════════════════════════════════════════════════

# file | redis | memcached
CACHE_DRIVER=file

# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# ═══════════════════════════════════════════════════════════════════════════════
# Queue (monkeyslegion-queue 2.0)
# ═══════════════════════════════════════════════════════════════════════════════

# null | database | redis
QUEUE_DEFAULT=null
# QUEUE_DEFAULT_QUEUE=default
# QUEUE_FAILED_QUEUE=failed
# QUEUE_PREFIX=ml_queue
# QUEUE_MAX_ATTEMPTS=3
# QUEUE_DATABASE_TABLE=jobs
# QUEUE_DATABASE_FAILED_TABLE=failed_jobs

# ═══════════════════════════════════════════════════════════════════════════════
# Mail (monkeyslegion-mail 2.0)
# ═══════════════════════════════════════════════════════════════════════════════

# smtp | sendmail | mailgun | monkeys_mail | null
MAIL_DRIVER=null
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun (uncomment if using mailgun driver)
# MAILGUN_DOMAIN=
# MAILGUN_SECRET=
# MAILGUN_REGION=us

# MonkeysMail (uncomment if using monkeys_mail driver)
# MONKEYS_MAIL_API_KEY=
# MONKEYS_MAIL_DOMAIN=monkeys.cloud

# ═══════════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════════

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════════════════════
# Dev Server
# ═══════════════════════════════════════════════════════════════════════════════

# auto | filewatcher | entr
ML_DEV_WATCHER=auto

# ═══════════════════════════════════════════════════════════════════════════════
# WebSocket Server (monkeyslegion-sockets)
# ═══════════════════════════════════════════════════════════════════════════════

# stream | swoole | react
WS_DRIVER=stream
WS_HOST=0.0.0.0
WS_PORT=8080
# local | redis
WS_REGISTRY=local
# unix | redis
WS_BROADCAST=unix
# json | msgpack
WS_FORMATTER=json
WS_UNIX_PATH=/tmp/ml_sockets.sock

# ═══════════════════════════════════════════════════════════════════════════════
# DevTools (monkeyslegion-devtools)
# ═══════════════════════════════════════════════════════════════════════════════

DEVTOOLS_ENABLED=true
# file | null
DEVTOOLS_STORAGE=file
# 0.0 – 1.0 (percentage of requests to profile)
DEVTOOLS_SAMPLE_RATE=1.0

###############################################################################
#  End of file — add custom variables below this line                         #
###############################################################################