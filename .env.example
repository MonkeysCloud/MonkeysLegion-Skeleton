###############################################################################
#  MonkeysLegion v2 – Environment Configuration                               #
#  Rename to `.env` for local use — NEVER commit this file                    #
###############################################################################

# ═══════════════════════════════════════════════════════════════════════════════
# Application
# ═══════════════════════════════════════════════════════════════════════════════

APP_NAME="MonkeysLegion App"
APP_ENV=development                # production | staging | development | testing
APP_DEBUG=true
APP_URL=http://localhost:8000
# APP_KEY=base64:...               # Generated by `php ml key:generate`

# ═══════════════════════════════════════════════════════════════════════════════
# Database (MySQL 8.4+ / PostgreSQL 16+)
# ═══════════════════════════════════════════════════════════════════════════════

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ml_skeleton
DB_USERNAME=root
DB_PASSWORD=root
DB_CHARSET=utf8mb4

# ═══════════════════════════════════════════════════════════════════════════════
# Authentication
# ═══════════════════════════════════════════════════════════════════════════════

JWT_SECRET=changeme-use-at-least-32-characters-of-randomness
JWT_ACCESS_TTL=1800                # 30 minutes
JWT_REFRESH_TTL=604800             # 7 days

# ═══════════════════════════════════════════════════════════════════════════════
# Session
# ═══════════════════════════════════════════════════════════════════════════════

SESSION_DRIVER=file                # file | database | redis
SESSION_LIFETIME=7200              # seconds
SESSION_ENCRYPT=false

# ═══════════════════════════════════════════════════════════════════════════════
# Cache
# ═══════════════════════════════════════════════════════════════════════════════

CACHE_DRIVER=file                  # file | redis | memcached

# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# ═══════════════════════════════════════════════════════════════════════════════
# Queue
# ═══════════════════════════════════════════════════════════════════════════════

QUEUE_CONNECTION=sync              # sync | database | redis

# ═══════════════════════════════════════════════════════════════════════════════
# Mail
# ═══════════════════════════════════════════════════════════════════════════════

MAIL_DRIVER=log                    # smtp | log | null
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════════

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════════════════════
# Dev Server
# ═══════════════════════════════════════════════════════════════════════════════

ML_DEV_WATCHER=auto                # auto | filewatcher | entr

###############################################################################
#  End of file — add custom variables below this line                         #
###############################################################################