###############################################################################
#  MonkeysLegion – default environment file (rename to `.env` for local use)  #
###############################################################################

# ---------------------------------------------------------------------------
#  Core application settings
# ---------------------------------------------------------------------------

# Current runtime environment:  dev | staging | prod
APP_ENV=dev

# Turn verbose error pages on/off; always set to "false" in production
APP_DEBUG=true

# Generated once by `bin/ml key:generate`; used for encryption/HMAC
# APP_KEY=base64:replace_me

# ---------------------------------------------------------------------------
#  Database connection (MySQL 8.4+)
# ---------------------------------------------------------------------------

# Data Source Name — include protocol, host, port, db name, and charset.
# If your MySQL server uses a UNIX socket, replace host+port with `unix_socket=/path/to/socket`.
DB_DSN="mysql:host=127.0.0.1;port=3306;dbname=myapp;charset=utf8mb4"

# MySQL username with at least SELECT/INSERT/UPDATE/DELETE rights on the database above
DB_USER="root"

# Password for the database user
DB_PASS="secret"

# ---------------------------------------------------------------------------
#  Optional: mail, cache, queue, etc. — uncomment as needed
# ---------------------------------------------------------------------------

# MAIL_DSN="smtp://user:pass@mail.example.com:587"
# CACHE_DRIVER=file        # available: file | redis | memcached
# QUEUE_DRIVER=sync        # available: sync | redis | rabbitmq

###############################################################################
#  End of file – add any custom variables below this line                     #
###############################################################################

# STRIPE KEYS
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY                  # Public key for client-side Stripe integrations
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY                            # Secret key for server-side Stripe API requests
STRIPE_TEST_KEY=sk_test_...                                         # Another test secret key (can be removed if not needed)
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET                    # Secret for verifying Stripe webhook signatures
STRIPE_WEBHOOK_SECRET_TEST=YOUR_STRIPE_WEBHOOK_SECRET_TEST          # Secret for verifying Stripe webhook signatures
STRIPE_API_VERSION=2025-04-30                                       # Stripe API version to use
STRIPE_CURRENCY=usd                                                 # Default currency for transactions
STRIPE_CURRENCY_LIMIT=100000                                        # Maximum transaction amount in smallest currency unit (e.g., cents)
STRIPE_WEBHOOK_TOLERANCE=20                                         # Time tolerance (in seconds) for webhook signature validation
STRIPE_WEBHOOK_DEFAULT_TTL=172800                                   # Default time-to-live (in seconds) for webhook events
STRIPE_IDEMPOTENCY_TABLE=stripe_memory                              # Database table for storing idempotency keys
STRIPE_TIMEOUT=60                                                   # Timeout (in seconds) for Stripe API requests
STRIPE_WEBHOOK_RETRIES=3                                            # Maximum number of retries for failed webhook events
STRIPE_MAX_PAYLOAD_SIZE=131072                                      # Maximum size (in bytes) for Stripe webhook payloads 128KB
STRIPE_API_URL=https://api.stripe.com                               # URL for Stripe's API endpoint
#-------------------------------------------------------------------------------